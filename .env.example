# Aletheia one-command docker compose defaults
POSTGRES_USER=aletheia
POSTGRES_PASSWORD=aletheia
POSTGRES_DB=aletheia

OPENSEARCH_INITIAL_ADMIN_PASSWORD=TempStrongPassw0rd!
OPENSEARCH_INDEX=aletheia_chunks
QDRANT_COLLECTION=aletheia_chunks

RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin

ALETHEIA_BRIDGE_TOKEN=change-me
ALETHEIA_BRIDGE_RATE_LIMIT_PER_MIN=60
ALETHEIA_BRIDGE_TIMEOUT=30

REDIS_URL=redis://localhost:40002/0
CACHE_ENABLED=true
CACHE_PREFIX=aletheia
SEARCH_CACHE_TTL=300
ASK_CACHE_TTL=180
RETRIEVAL_BM25_WEIGHT=0.65
RETRIEVAL_VECTOR_WEIGHT=0.35
ALETHEIA_QUEUE=aletheia_ingest
