---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Aletheia Gateway - Batch Upload">
	<div class="max-w-7xl mx-auto px-6 w-full flex flex-col items-center pt-8 md:pt-16 min-h-[70vh]">
		
		<div class="text-center space-y-4 max-w-4xl mx-auto mb-12">
			<h1 class="hero-title text-slate-900 leading-none">
				Gateway to <span class="text-[#3B82F6]">Truth.</span>
			</h1>
			<p class="text-slate-600 text-lg md:text-xl max-w-2xl mx-auto font-light">
				Securely ingest multiple enterprise documents securely into the Aletheia semantic pipeline.
			</p>
		</div>

		<!-- STATE 1: BATCH UPLOAD CONFIG -->
		<div id="setup-view" class="w-full max-w-3xl">
			<div class="card bg-white p-8 relative overflow-hidden group border-2 border-dashed border-gray-300 hover:border-[#3B82F6] transition-all cursor-pointer text-center" id="dropzone">
                <input type="file" id="file-input" class="hidden" required accept=".pdf,.txt,.md,.csv,.json,.docx" multiple />
                
                <div id="empty-state">
                    <div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center text-[#3B82F6] mx-auto mb-4 group-hover:scale-110 transition-transform">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
                    </div>
                    <h3 class="text-xl font-bold text-slate-800" style="font-family: var(--font-outfit)">Drag & drop multiple files</h3>
                    <p class="text-slate-500 mt-2 text-sm">or <span class="text-[#3B82F6] font-semibold">Browse Files</span></p>
                </div>

                <div id="file-list-container" class="text-left hidden w-full">
                    <div class="flex justify-between items-end border-b pb-2 mb-3">
                        <h4 class="font-semibold text-slate-700">Selected Files (<span id="file-count">0</span>)</h4>
                        <button type="button" id="clear-files-btn" class="text-xs text-red-500 hover:text-red-700 uppercase font-bold tracking-wider relative z-10">Clear All</button>
                    </div>
                    <ul id="file-list" class="space-y-2 max-h-48 overflow-y-auto pr-2 custom-scrollbar relative z-10"></ul>
                </div>
			</div>

            <form id="batch-form" class="card mt-6 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-slate-700">Domain / Collection</label>
                        <select id="meta-domain" class="input bg-white cursor-pointer">
                            <option value="general">General Knowledge</option>
                            <option value="finance">Finance</option>
                            <option value="security">Security & IT</option>
                            <option value="hr">Human Resources</option>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-slate-700">Language</label>
                        <select id="meta-language" class="input bg-white cursor-pointer">
                            <option value="en">English</option>
                            <option value="vi">Tiếng Việt</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-semibold text-slate-700">Tags</label>
                    <input type="text" id="meta-tags" placeholder="e.g. q1-report, internal, confidential" class="input" />
                </div>

                <div class="flex flex-wrap gap-4 pt-2 border-t border-gray-100 mt-4 pt-4">
                    <label class="flex items-center space-x-2 text-sm text-slate-700 cursor-pointer">
                        <input type="checkbox" id="meta-ocr" class="rounded border-gray-300 text-[#3B82F6] focus:ring-[#3B82F6]" />
                        <span>OCR if scanned</span>
                    </label>
                    <label class="flex items-center space-x-2 text-sm text-slate-700 cursor-pointer">
                        <input type="checkbox" id="meta-skip-dup" class="rounded border-gray-300 text-[#3B82F6] focus:ring-[#3B82F6]" checked />
                        <span>Skip duplicates</span>
                    </label>
                    <label class="flex items-center space-x-2 text-sm text-slate-700 cursor-pointer">
                        <input type="checkbox" id="meta-auto-enrich" class="rounded border-gray-300 text-[#3B82F6] focus:ring-[#3B82F6]" checked />
                        <span>Auto-run enrichment</span>
                    </label>
                </div>

                <button type="submit" id="submit-btn" class="btn-primary w-full mt-4 py-3 text-lg flex justify-center items-center gap-2 opacity-50 cursor-not-allowed" disabled>
                    Upload Files
                </button>
            </form>
            
            <div id="upload-error-msg" class="mt-4 text-center text-sm font-medium p-4 rounded-lg bg-red-50 text-red-600 hidden"></div>
		</div>

        <!-- STATE 2: PROGRESS BOARD -->
        <div id="progress-view" class="w-full max-w-4xl hidden flex-col space-y-6 pb-20">
            <div class="bg-slate-900 text-white rounded-xl p-6 shadow-xl flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="text-center md:text-left">
                    <h3 class="text-xl font-bold" style="font-family: var(--font-outfit)">Batch Processing</h3>
                    <p class="text-slate-400 text-sm mt-1">Batch ID: <span id="board-batch-id" class="font-mono text-blue-400">...</span></p>
                </div>
                <div class="flex space-x-6 text-center divide-x divide-slate-700">
                    <div class="pl-0"><div class="text-2xl font-bold" id="metric-total">0</div><div class="text-xs text-slate-400 uppercase tracking-wider mt-1">Total</div></div>
                    <div class="pl-6"><div class="text-2xl font-bold text-green-400" id="metric-done">0</div><div class="text-xs text-slate-400 uppercase tracking-wider mt-1">Done</div></div>
                    <div class="pl-6"><div class="text-2xl font-bold text-blue-400" id="metric-active">0</div><div class="text-xs text-slate-400 uppercase tracking-wider mt-1">Active</div></div>
                    <div class="pl-6"><div class="text-2xl font-bold text-red-400" id="metric-failed">0</div><div class="text-xs text-slate-400 uppercase tracking-wider mt-1">Failed</div></div>
                </div>
            </div>

            <div class="card overflow-hidden !p-0">
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-slate-600 min-w-[600px]">
                        <thead class="bg-slate-50 text-slate-700 font-semibold border-b">
                            <tr>
                                <th class="px-6 py-4 w-1/2">Filename</th>
                                <th class="px-6 py-4 w-1/4">Status</th>
                                <th class="px-6 py-4 w-1/4 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="job-table-body" class="divide-y divide-gray-100">
                            <!-- Populated dynamically via JS -->
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="completion-panel" class="hidden card text-center space-y-4 border-2 border-green-200 bg-green-50/30">
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center text-green-600 mx-auto">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-800" style="font-family: var(--font-outfit)">Ingestion Complete</h3>
                <p class="text-slate-600 max-w-lg mx-auto pb-2" id="completion-desc">All files have been successfully processed into the Aletheia pipeline.</p>
                <div class="flex flex-col sm:flex-row justify-center gap-4 pt-2">
                    <button class="btn-secondary" onclick="window.location.reload()">Upload New Batch</button>
                    <button class="btn-primary !bg-slate-900 hover:!opacity-80">Ask This Batch</button>
                </div>
            </div>
        </div>

	</div>
</Layout>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 4px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
</style>

<script>
    // --- State ---
	let selectedFiles: File[] = [];
    let currentBatchId: string | null = null;
    let pollingInterval: number | null = null;

    // --- DOM Elements ---
	const setupView = document.getElementById('setup-view')!;
	const progressView = document.getElementById('progress-view')!;
    
	const dropzone = document.getElementById('dropzone')!;
	const fileInput = document.getElementById('file-input') as HTMLInputElement;
	const batchForm = document.getElementById('batch-form') as HTMLFormElement;
	const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    
	const emptyState = document.getElementById('empty-state')!;
	const fileListContainer = document.getElementById('file-list-container')!;
	const fileListUl = document.getElementById('file-list')!;
	const fileCountSpan = document.getElementById('file-count')!;
	const clearFilesBtn = document.getElementById('clear-files-btn')!;
    const uploadErrorMsg = document.getElementById('upload-error-msg')!;

    // Board Elements
    const boardBatchIdSpan = document.getElementById('board-batch-id')!;
    const metricTotal = document.getElementById('metric-total')!;
    const metricDone = document.getElementById('metric-done')!;
    const metricActive = document.getElementById('metric-active')!;
    const metricFailed = document.getElementById('metric-failed')!;
    const jobTableBody = document.getElementById('job-table-body')!;
    const completionPanel = document.getElementById('completion-panel')!;
    const completionDesc = document.getElementById('completion-desc')!;

    // --- Utilities ---
    const formatBytes = (bytes: number, decimals = 2) => {
        if (!+bytes) return '0 Bytes'
        const k = 1024
        const dm = decimals < 0 ? 0 : decimals
        const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB']
        const i = Math.floor(Math.log(bytes) / Math.log(k))
        return `${parseFloat((bytes / Math.pow(k, i)).toFixed(dm))} ${sizes[i]}`
    }

    const getStatusTheme = (status: string) => {
        switch(status?.toLowerCase()) {
            case 'finished': case 'done': return { cls: 'bg-green-100 text-green-700 border-green-200', text: 'Completed', dot: 'bg-green-500' };
            case 'failed': case 'error': return { cls: 'bg-red-100 text-red-700 border-red-200', text: 'Failed', dot: 'bg-red-500' };
            case 'queued': case 'queue_unavailable': return { cls: 'bg-slate-100 text-slate-700 border-slate-200', text: 'Queued', dot: 'bg-slate-400' };
            case 'canceled': return { cls: 'bg-gray-100 text-gray-700 border-gray-200', text: 'Canceled', dot: 'bg-gray-400' };
            default: return { cls: 'bg-blue-100 text-blue-700 border-blue-200', text: 'Processing', dot: 'bg-blue-500 animate-pulse' };
        }
    }

    // --- Interactions: Setup View ---
	dropzone?.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('#clear-files-btn') || (e.target as HTMLElement).closest('button')) return;
		fileInput.click();
	});

	fileInput?.addEventListener('change', (e) => {
		const target = e.target as HTMLInputElement;
		if (target.files && target.files.length > 0) {
			addFiles(Array.from(target.files));
		}
	});

	['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
		dropzone?.addEventListener(eventName, e => {
            e.preventDefault(); e.stopPropagation();
        }, false);
	});

	['dragenter', 'dragover'].forEach(eventName => {
		dropzone?.addEventListener(eventName, () => {
			dropzone.classList.add('border-[#3B82F6]', 'bg-blue-50/30');
		}, false);
	});

	['dragleave', 'drop'].forEach(eventName => {
		dropzone?.addEventListener(eventName, () => {
			dropzone.classList.remove('border-[#3B82F6]', 'bg-blue-50/30');
		}, false);
	});

	dropzone?.addEventListener('drop', (e: DragEvent) => {
		const dt = e.dataTransfer;
		if (dt && dt.files && dt.files.length > 0) {
			addFiles(Array.from(dt.files));
		}
	});

    clearFilesBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        selectedFiles = [];
        fileInput.value = '';
        renderFileList();
    });

	function addFiles(files: File[]) {
        // Simple deduplication block based on filename & size
        files.forEach(newFile => {
            if (!selectedFiles.some(f => f.name === newFile.name && f.size === newFile.size)) {
                selectedFiles.push(newFile);
            }
        });
        renderFileList();
	}

    function renderFileList() {
        if (selectedFiles.length === 0) {
            emptyState.classList.remove('hidden');
            fileListContainer.classList.add('hidden');
            submitBtn.disabled = true;
            submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
            submitBtn.innerHTML = 'Upload Files';
            return;
        }

        emptyState.classList.add('hidden');
        fileListContainer.classList.remove('hidden');
        fileCountSpan.textContent = selectedFiles.length.toString();
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        submitBtn.innerHTML = `Upload ${selectedFiles.length} File${selectedFiles.length > 1 ? 's' : ''}`;

        fileListUl.innerHTML = '';
        selectedFiles.forEach((file, idx) => {
            const li = document.createElement('li');
            li.className = "flex justify-between items-center bg-slate-50 border border-slate-100 p-3 rounded-lg text-sm group/item";
            li.innerHTML = `
                <div class="flex items-center space-x-3 truncate">
                    <svg class="w-5 h-5 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <span class="font-medium text-slate-700 truncate">${file.name}</span>
                    <span class="text-slate-400 shrink-0 hidden md:inline-block">(${formatBytes(file.size)})</span>
                </div>
                <button type="button" class="text-slate-400 hover:text-red-500 p-1 opacity-0 group-hover/item:opacity-100 transition-opacity flex-shrink-0" onclick="window.removeFile(${idx})">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            `;
            fileListUl.appendChild(li);
        });
    }

    // Expose layout remove trick to global window
    (window as any).removeFile = (index: number) => {
        selectedFiles.splice(index, 1);
        renderFileList();
    }

    // --- Backend Submission ---
	batchForm?.addEventListener('submit', async (e) => {
		e.preventDefault();
		if (selectedFiles.length === 0) return;

        // Collect Metadata
		const metaDomain = (document.getElementById('meta-domain') as HTMLSelectElement).value;
		const metaLanguage = (document.getElementById('meta-language') as HTMLSelectElement).value;
		const metaTags = (document.getElementById('meta-tags') as HTMLInputElement).value;
		const metaOcr = (document.getElementById('meta-ocr') as HTMLInputElement).checked;
		const metaSkipDup = (document.getElementById('meta-skip-dup') as HTMLInputElement).checked;
		const metaAutoEnrich = (document.getElementById('meta-auto-enrich') as HTMLInputElement).checked;

        const metadata = {
            domain: metaDomain,
            language: metaLanguage,
            tags: metaTags.split(',').map(s => s.trim()).filter(Boolean),
            ocr_enabled: metaOcr,
            skip_duplicates: metaSkipDup,
            auto_enrich: metaAutoEnrich
        };

		const formData = new FormData();
        selectedFiles.forEach((f) => {
            formData.append('files', f);
        });
        formData.append('metadata', JSON.stringify(metadata));
		
        submitBtn.innerHTML = `<svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Uploading...`;
        submitBtn.setAttribute('disabled', 'true');
        uploadErrorMsg.classList.add('hidden');

		try {
			const res = await fetch(`http://localhost:8080/upload/batch`, {
				method: 'POST',
				body: formData,
			});

			if (!res.ok) {
                const errData = await res.json().catch(() => null);
				throw new Error(errData?.detail || `Upload failed with status ${res.status}`);
			}

			const data = await res.json();
            currentBatchId = data.batch_id;
            
            // Switch UI states
            setupView.classList.add('hidden');
            progressView.classList.remove('hidden');
            progressView.classList.add('flex');
            boardBatchIdSpan.textContent = currentBatchId!;

            // Begin Polling
            startPolling();

		} catch (error: any) {
			console.error('Batch Upload Error:', error);
            uploadErrorMsg.textContent = error.message || 'Failed to communicate with gateway API.';
            uploadErrorMsg.classList.remove('hidden');
			submitBtn.disabled = false;
            submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            submitBtn.innerHTML = `Upload ${selectedFiles.length} File${selectedFiles.length > 1 ? 's' : ''}`;
		}
	});

    // --- Progress Board Logic ---
    function startPolling() {
        fetchBatchStatus(); // initial hit
        pollingInterval = window.setInterval(fetchBatchStatus, 2500); // 2.5sec interval
    }

    async function fetchBatchStatus() {
        if (!currentBatchId) return;

        try {
            const res = await fetch(`http://localhost:8080/upload/batch/${currentBatchId}`);
            if (!res.ok) return;
            const data = await res.json();
            updateBoardUI(data);

            // Check completion conditions
            if (data.summary.in_progress === 0 && data.summary.total > 0) {
                window.clearInterval(pollingInterval!);
                completionPanel.classList.remove('hidden');
                if (data.summary.failed > 0) {
                    completionDesc.textContent = `Completed with errors. ${data.summary.done} indexed, ${data.summary.failed} failed.`;
                }
            }
        } catch (err) {
            console.warn("Polling error", err);
        }
    }

    function updateBoardUI(data: any) {
        metricTotal.textContent = data.summary.total;
        metricDone.textContent = data.summary.done;
        metricActive.textContent = data.summary.in_progress;
        metricFailed.textContent = data.summary.failed;

        jobTableBody.innerHTML = '';
        data.jobs.forEach((job: any) => {
            const theme = getStatusTheme(job.status);
            
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="px-6 py-4 font-medium text-slate-800 break-all max-w-xs" title="${job.filename}">${job.filename}</td>
                <td class="px-6 py-4">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium border ${theme.cls}">
                        <span class="w-1.5 h-1.5 rounded-full mr-1.5 ${theme.dot}"></span>
                        ${theme.text}
                    </span>
                </td>
                <td class="px-6 py-4 text-right space-x-2">
                    ${job.status === 'failed' ? `<button onclick="window.retryJob('${job.job_id}')" class="text-xs font-bold text-[#F97316] hover:underline uppercase tracking-wide">Retry</button>` : ''}
                    ${job.status === 'queued' || ['started', 'deferred'].includes(job.status) ? `<button onclick="window.cancelJob('${job.job_id}')" class="text-xs font-bold text-red-500 hover:underline uppercase tracking-wide">Cancel</button>` : ''}
                    ${job.status === 'finished' ? `<span class="text-xs text-green-600 font-bold uppercase tracking-wide">Success</span>` : ''}
                    ${job.status === 'canceled' ? `<span class="text-xs text-gray-500 font-bold uppercase tracking-wide">Stopped</span>` : ''}
                </td>
            `;
            jobTableBody.appendChild(tr);
        });
    }

    (window as any).retryJob = async (jobId: string) => {
        await fetch(`http://localhost:8080/jobs/${jobId}/retry`, { method: 'POST' });
        fetchBatchStatus(); // fast refresh
    }

    (window as any).cancelJob = async (jobId: string) => {
        await fetch(`http://localhost:8080/jobs/${jobId}/cancel`, { method: 'POST' });
        fetchBatchStatus(); // fast refresh
    }
</script>
